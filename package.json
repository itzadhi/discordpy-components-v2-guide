{
  "name": "discordpy-components-v2-guide",
  "version": "1.0.0",
  "private": false,
  "description": "Modern discord.py 2.x Components learning ecosystem with academy lessons, production architecture, references, and verified Python examples.",
  "author": "itzadhi",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint-content.mjs",
    "test:examples": "python scripts/validate_examples.py && node scripts/validate-examples.mjs",
    "check:readme": "node scripts/check-readme.mjs",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "verify": "npm run lint && npm run typecheck && npm run test:examples && npm run check:readme && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/postcss": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.12.1",
    "next": "^16.2.6",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-pretty-code": "^0.14.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "markdown-it": "^14.1.0",
    "prettier": "^3.7.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/itzadhi/discordpy-components-v2-guide.git"
  },
  "bugs": {
    "url": "https://github.com/itzadhi/discordpy-components-v2-guide/issues"
  },
  "homepage": "https://itzadhi.github.io/discordpy-components-v2-guide/",
  "keywords": [
    "discord",
    "discordpy",
    "components-v2",
    "slash-commands",
    "discord-api",
    "academy",
    "guide",
    "typescript",
    "mdx",
    "nextjs"
  ]
}
